{
  "name": "@sloerstudio/web",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "analyze": "ANALYZE=true next build",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "npx prisma studio",
    "db:generate:enterprise": "npx prisma generate --schema prisma/schema.enterprise.prisma",
    "db:push:enterprise": "npx prisma db push --schema prisma/schema.enterprise.prisma",
    "db:migrate:enterprise": "npx prisma migrate dev --schema prisma/schema.enterprise.prisma",
    "video:render": "npx tsx scripts/render-product-videos.ts",
    "video:render:one": "npx tsx scripts/render-product-videos.ts"
  },
