# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# Windows scripts keep CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binaries — no conversion
*.bin binary
*.exe binary
*.dll binary
*.msi binary
*.dmg binary
*.AppImage binary
*.deb binary
*.ico binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ttf binary
*.woff binary
*.woff2 binary
