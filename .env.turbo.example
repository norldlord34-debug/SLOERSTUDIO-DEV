# Turborepo Remote Cache — Vercel
# Copy this file to .env.turbo and fill in your values.
# Get these from: https://vercel.com/account/tokens
#
# TURBO_TOKEN  — your personal Vercel access token
# TURBO_TEAM   — your Vercel team slug (e.g. "sloerstudio")
#
# Once set, every CI run and local build will share the same remote cache.
# First build: ~normal speed. All subsequent builds with no changes: <5s.

TURBO_TOKEN=your_vercel_token_here
TURBO_TEAM=sloerstudio
